# Kopieer naar .env en vul je eigen waarden in. .env blijft buiten git.

# TimingPointCode van jouw halte-richting. Elke richting heeft een eigen TPC;
# bepaal de juiste met: python scripts/find_tpc.py <TPC1> <TPC2> --line <lijn> --dest "<bestemming>"
# (54460130 = Katwijk, Gemeentehuis richting Den Haag CS)
OVAPI_TPC=54460130

# Hoe vaak de container OVapi pollt, in seconden. Fair use: default 180,
# waarden onder 60 worden geclampt naar 60.
POLL_INTERVAL_SECONDS=180

# Identificerende User-Agent richting OVapi (fair use). Vul iets herkenbaars in.
USER_AGENT=ovapi-departures-proxy/1.0 (+https://github.com/<jouw-gebruikersnaam>/ovapi-departures-proxy)

# Poort waarop de HTTP-API luistert (gebonden op 0.0.0.0).
PORT=8000

# Optioneel: alleen deze lijnen tonen (comma-separated). Leeg = alle lijnen.
LINE_FILTER=

# Maximum aantal vertrekken in /departures. 0 = onbeperkt.
LIMIT=4

# Tijdzone van de container; OVapi-tijden worden altijd als Europe/Amsterdam geparst.
TZ=Europe/Amsterdam
